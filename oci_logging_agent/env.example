# ============================================================
# Store 1: OCI Streaming (native)
# Used by Connector Hub to deliver events from OCI Logging
# Auth: SASL/PLAIN with OCI Auth Token
# ============================================================

# Broker endpoint — found in OCI Console → Streaming → Stream Pools → Kafka Connection Settings
# Format: cell-1.streaming.<region>.oci.oraclecloud.com:9092
OCI_STREAMING_BOOTSTRAP=cell-1.streaming.us-phoenix-1.oci.oraclecloud.com:9092

# Stream pool OCID — found in OCI Console → Streaming → Stream Pools
OCI_STREAM_POOL_OCID=ocid1.streampool.oc1.<region>.<unique_id>

# SASL username — format is: <tenancy_name>/<oci_username>/<stream_pool_ocid>
OCI_SASL_USERNAME=<tenancy_name>/<username>/<stream_pool_ocid>

# OCI Auth Token (this is NOT your console password)
# Generate at: OCI Console → Profile (top right) → Auth Tokens → Generate Token
OCI_AUTH_TOKEN=YOUR_OCI_AUTH_TOKEN

# ============================================================
# Store 2: OCI Streaming for Apache Kafka
# Used by DeltaStream to write enriched output streams
# Auth: SASL/SCRAM-SHA-512 with dedicated super-user credentials
# ============================================================

# Broker endpoint — found in OCI Console → Streaming → your Kafka cluster → Bootstrap Servers
# Format: bootstrap-ext-<unique_id>.kafka.<region>.oci.oraclecloud.com:10000
OCI_KAFKA_BOOTSTRAP=bootstrap-ext-<unique_id>.kafka.<region>.oci.oraclecloud.com:10000

# Super-user credentials — created when provisioning the Kafka cluster
# Found in OCI Console → Streaming → your cluster → Users
OCI_KAFKA_USERNAME=super-user-<unique_id>
OCI_KAFKA_PASSWORD=YOUR_KAFKA_SUPER_USER_PASSWORD

# ============================================================
# Topic Names
# OCI Connector Hub will create these — match them here
# ============================================================
OCI_AUDIT_TOPIC=oci-audit-raw
OCI_LOGGING_TOPIC=oci-logging-raw

# ============================================================
# DeltaStream
# ============================================================
DELTASTREAM_API_URL=https://api.deltastream.io/v2
DELTASTREAM_TOKEN=YOUR_DELTASTREAM_API_TOKEN

# ============================================================
# OpenAI
# ============================================================
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
